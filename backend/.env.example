# MongoDB Connection
# Use MongoDB Atlas (free tier) or any MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/apireg?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Server Configuration
PORT=5000

# Email Configuration (for nodemailer)
# Example using Gmail App Password or other SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@apireg.com

# Frontend URL (for CORS and email links)
FRONTEND_URL=https://your-frontend.vercel.app

# Admin Credentials (will be created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

